generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String
  created_at DateTime @default(now())

  @@map("admins")
}

model Doctor {
  id          Int        @id @default(autoincrement())
  nama        String
  spesialis   String
  foto        String?
  deskripsi   String?    @db.Text
  created_at  DateTime   @default(now())
  schedules   Schedule[]

  @@map("doctors")
}

model Schedule {
  id          Int    @id @default(autoincrement())
  doctor_id   Int
  hari        String
  jam_mulai   String
  jam_selesai String
  doctor      Doctor @relation(fields: [doctor_id], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model News {
  id      Int      @id @default(autoincrement())
  judul   String
  isi     String   @db.LongText
  gambar  String?
  tanggal DateTime @default(now())

  @@map("news")
}

model Facility {
  id        Int    @id @default(autoincrement())
  nama      String
  deskripsi String? @db.Text
  gambar    String?

  @@map("facilities")
}

model Achievement {
  id        Int    @id @default(autoincrement())
  judul     String
  deskripsi String? @db.Text
  tahun     Int?
  gambar    String?

  @@map("achievements")
}

model Promotion {
  id               Int      @id @default(autoincrement())
  judul            String
  deskripsi        String?  @db.Text
  gambar           String?
  tanggal_mulai    DateTime
  tanggal_berakhir DateTime

  @@map("promotions")
}

model Contact {
  id        Int    @id @default(autoincrement())
  telepon   String?
  email     String?
  alamat    String? @db.Text
  maps_link String? @db.Text

  @@map("contacts")
}

model Setting {
  id           Int      @id @default(autoincrement())
  linktree_url String?
  updated_at   DateTime @updatedAt

  @@map("settings")
}
